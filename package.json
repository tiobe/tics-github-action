{
  "name": "tics-github-action",
  "version": "2.8.0",
  "description": "The TICS Github action integrates TICS Client analysis to measure your code quality. The incorporated Quality gating feature enables you to analyze and decorate pull requests.",
  "main": "lib/main.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc -noEmit",
    "lint": "eslint .",
    "package": "npm run build && ncc build --license licenses.txt",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiobe/tics-github-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "TIOBE",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tiobe/tics-github-action/issues"
  },
  "homepage": "https://github.com/tiobe/tics-github-action#readme",
  "dependencies": {
    "@actions/artifact": "^6.2.0",
    "@actions/artifact-v1": "npm:@actions/artifact@1.1.2",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/plugin-paginate-graphql": "^6.0.0",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/request-error": "^7.1.0",
    "@tiobe/http-client": "1.0.0",
    "@tiobe/install-tics": "0.6.1",
    "canonical-path": "^1.0.0",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.23",
    "node-fetch": "^2.7.0",
    "proxy-agent": "^6.5.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@octokit/graphql-schema": "^15.26.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.3",
    "@types/node-fetch": "^2.6.13",
    "@types/semver": "^7.7.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "http-proxy": "^1.18.1",
    "prettier": "3.8.1",
    "proxy": "^2.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
